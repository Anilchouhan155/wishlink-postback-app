# Database - use Neon (free) for Vercel: https://neon.tech
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_URL=postgresql://user:pass@host/db?sslmode=require

# Shopify App Credentials (auto-populated by `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_orders

# Wishlink Postback Configuration
WISHLINK_POSTBACK_BASE_URL=http://wishlink.com
WISHLINK_GOAL_ID=default_goal
WISHLINK_CAMPAIGN_ID=default_campaign
WISHLINK_CREATIVE_ID=default_creative

# Optional: Postback timeout (ms) and retries
POSTBACK_TIMEOUT_MS=10000
POSTBACK_MAX_RETRIES=3

# Optional: Enable verbose debug logging
# DEBUG=1
